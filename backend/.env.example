# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/collabboard

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:5173

# AI (OpenAI-compatible). Works with OpenAI directly, or with Groq by
# setting OPENAI_BASE_URL to Groq's OpenAI-compatible endpoint.
OPENAI_API_KEY=gsk_your_actual_groq_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant

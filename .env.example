# This file is used by `docker compose up` for variable substitution in
# docker-compose.yml (Compose automatically reads a .env file in the same
# directory as the compose file). It is separate from backend/.env and
# frontend/.env, which are used for local (non-Docker) development.
#
# Copy this to .env before running `docker compose up`:
#   cp .env.example .env

JWT_SECRET=replace_this_with_a_long_random_secret_key

# AI (OpenAI-compatible). Works with OpenAI directly, or with Groq by
# setting OPENAI_BASE_URL to Groq's OpenAI-compatible endpoint. Leave both
# blank to run without AI features - the rest of the app works fine either way.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
